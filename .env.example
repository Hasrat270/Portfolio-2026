# Public site URL (used for metadata, sitemap, OG, JSON-LD).
# Replace with your real deployed URL — leave blank to fall back to localhost.
NEXT_PUBLIC_SITE_URL=

# Optional: raises GitHub API rate limit for the live GitHub stats section
# (a read-only Personal Access Token is enough).
GITHUB_TOKEN=

# Optional: enables real email delivery for /api/contact via Resend.
# Without these, contact form messages are only logged to the server console.
RESEND_API_KEY=
CONTACT_FROM="Portfolio <onboarding@resend.dev>"
# Override the recipient inbox. Defaults to SITE.email in src/lib/site.ts.
CONTACT_TO=
